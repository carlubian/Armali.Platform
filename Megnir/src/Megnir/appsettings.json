{
  // NOTA DE SEGURIDAD (RNF3): el secreto de conexión de Azure (connection string / SAS)
  // NO se define aquí ni se versiona. Se inyecta en tiempo de ejecución mediante la
  // variable de entorno MEGNIR_AZURE_CONNECTIONSTRING (ver README.md de este proyecto).
  "Megnir": {
    "Apps": [
      { "Name": "app-a", "Paths": [ "/srv/app-a/data", "/srv/app-a/config" ] },
      { "Name": "app-b", "Paths": [ "/var/lib/app-b" ] }
    ],
    "Azure": {
      "Container": "megnir-backups",
      "HostPrefix": "auto"
    },
    "Retention": { "KeepLast": 4 },
    "SizeWarningMb": 100
  }
}
