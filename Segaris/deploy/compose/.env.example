# Segaris Compose configuration example.
#
# Copy to ".env" in this directory for local container execution:
#   cp .env.example .env
# The real ".env" is untracked and must never contain committed secrets.
#
# In production these values are supplied by Portainer as stack environment
# variables rather than a committed file.

# ---------------------------------------------------------------------------
# Ingress
# ---------------------------------------------------------------------------
# Host port published by Caddy. Clients reach Segaris at http://<server>:<port>/.
SEGARIS_HTTP_PORT=5525

# ---------------------------------------------------------------------------
# Persistent host storage (production / full local stack)
# ---------------------------------------------------------------------------
# Root host path for the attachments, backups, and Data Protection key bind
# mounts. The subdirectories must exist and be owned by UID:GID 5525:5525
# before the stack starts (see scripts/host-provision.sh).
SEGARIS_DATA_PATH=/data/volumes/segaris

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
SEGARIS_POSTGRES_DB=segaris
SEGARIS_POSTGRES_USER=segaris
# REQUIRED. No default. Use a strong, unique value. Secret: never commit a real value.
SEGARIS_POSTGRES_PASSWORD=

# ---------------------------------------------------------------------------
# First-administrator bootstrap (optional, idempotent)
# ---------------------------------------------------------------------------
# Set these only for the very first deployment to create the first administrator,
# then clear them. Secret: never commit a real password.
SEGARIS_BOOTSTRAP_USERNAME=
SEGARIS_BOOTSTRAP_PASSWORD=

# ---------------------------------------------------------------------------
# Optional Seq log delivery
# ---------------------------------------------------------------------------
SEGARIS_SEQ_ENABLED=false
SEGARIS_SEQ_SERVERURL=
# Secret: never commit a real value.
SEGARIS_SEQ_APIKEY=

# ---------------------------------------------------------------------------
# Images (production pulls immutable commit-SHA tags from the private registry)
# ---------------------------------------------------------------------------
# Local builds default to ":local"; production overrides these with registry tags.
SEGARIS_BACKEND_IMAGE=segaris-backend:local
SEGARIS_CADDY_IMAGE=segaris-caddy:local
SEGARIS_FRONTEND_IMAGE=segaris-frontend:local
# Public build-time release identifier used by frontend diagnostics.
SEGARIS_FRONTEND_VERSION=local

# ASP.NET Core environment for the backend container.
ASPNETCORE_ENVIRONMENT=Production

# ---------------------------------------------------------------------------
# Infrastructure-only dev stack (docker-compose.infra.yml)
# ---------------------------------------------------------------------------
SEGARIS_POSTGRES_PORT=5432
SEGARIS_SEQ_UI_PORT=5341
