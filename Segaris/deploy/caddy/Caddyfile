# Segaris ingress routing.
#
# Caddy is the only household-facing service. It listens on port 80 inside its
# container; the published host port is controlled by the Compose port mapping
# (SEGARIS_HTTP_PORT, default 5525). Segaris is served over plain HTTP on a
# trusted local network; TLS is intentionally out of scope.

{
	# No public domains or certificates are managed here.
	auto_https off
	# The admin API is not needed and is disabled to reduce surface area.
	admin off
}

:80 {
	# Backend REST API. Everything under /api/ is proxied to the backend.
	# Health endpoints (/health/live, /health/ready) stay internal to the
	# Compose network and are not routed through Caddy.
	handle /api/* {
		reverse_proxy backend:8080
	}

	# Everything else is the frontend single-page application.
	handle {
		reverse_proxy frontend:80
	}

	encode gzip

	log {
		output stdout
		format console
	}
}
