# Public, build-time frontend configuration.
#
# Every value here is embedded into the static bundle by Vite and is therefore
# public. Never place secrets, connection strings, or backend-only configuration
# in this file or any VITE_* variable. See
# docs/planning/FRONTEND_FOUNDATION_DECISIONS.md.

# Relative API path prefix. The application requires a same-origin relative path
# so session and antiforgery cookies behave identically locally and when
# deployed; absolute cross-origin URLs are rejected.
VITE_API_BASE_URL=/api

# Non-secret release identifier surfaced in safe diagnostics. Local development
# uses "development"; the production build may replace it with the Git commit SHA.
VITE_APP_VERSION=development
