{
  "ConnectionStrings": {
    "Segaris": "Data Source=segaris.local.db"
  },
  "Segaris": {
    "Database": {
      "Provider": "Sqlite"
    },
    "Storage": {
      "DataProtectionKeysPath": "",
      "AttachmentsPath": "attachments.local",
      "BackupsPath": "backups.local"
    },
    "Identity": {
      "Bootstrap": {
        "UserName": "",
        "Password": ""
      }
    },
    "Observability": {
      "Seq": {
        "Enabled": false,
        "ServerUrl": "",
        "ApiKey": "",
        "MinimumLevel": "Information"
      }
    },
    "Diagnostics": {
      "MaxBodyBytes": 16384,
      "PermitLimit": 30,
      "WindowSeconds": 60
    },
    "Mcp": {
      "Enabled": false
    }
  },
  "AllowedHosts": "*",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
