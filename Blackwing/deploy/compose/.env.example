BLACKWING_POSTGRES_PASSWORD=change-me
BLACKWING_POSTGRES_DB=blackwing
BLACKWING_POSTGRES_USER=blackwing
BLACKWING_HTTP_PORT=5055
BLACKWING_INITIAL_ADMIN_USERNAME=admin
BLACKWING_INITIAL_ADMIN_PASSWORD=admin-password-here

# Images. Local builds default to ":local"; production overrides these with the
# immutable commit-SHA tags pushed to the private registry / ACR, e.g.
#   BLACKWING_BACKEND_IMAGE=<acr-login-server>/blackwing-backend:<commit-sha>
#   BLACKWING_FRONTEND_IMAGE=<acr-login-server>/blackwing-frontend:<commit-sha>
BLACKWING_BACKEND_IMAGE=blackwing-backend:local
BLACKWING_FRONTEND_IMAGE=blackwing-frontend:local
